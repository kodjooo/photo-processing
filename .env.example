# Токен Telegram-бота. Получить у BotFather.
BOT_TOKEN=replace-me
# OAuth-токен Яндекс Диска для загрузки результата. Получить в кабинете Яндекс OAuth.
YANDEX_DISK_OAUTH_TOKEN=replace-me
# Базовый путь на Яндекс Диске, куда загружаются результаты.
YANDEX_DISK_BASE_PATH=/photo-processing/results
# DSN PostgreSQL внутри docker compose.
DATABASE_URL=postgresql+asyncpg://photo_user:photo_password@postgres:5432/photo_processing
# URL Redis внутри docker compose.
REDIS_URL=redis://redis:6379/0
# Папка временных файлов задач внутри контейнеров.
JOB_STORAGE_ROOT=/tmp/jobs
# Путь к левому логотипу внутри контейнера.
LEFT_LOGO_PATH=/app/assets/logo-left.png
# Путь к правому логотипу внутри контейнера.
RIGHT_LOGO_PATH=/app/assets/logo-right.png
# Максимальный размер входного архива в байтах.
MAX_ARCHIVE_SIZE_BYTES=5368709120
# Максимальное количество файлов в архиве.
MAX_ARCHIVE_FILES=300
# Максимальное количество изображений в обработке.
MAX_IMAGE_FILES=200
# Число потоков обработки изображений внутри одной задачи.
IMAGE_PROCESSING_CONCURRENCY=2
# Число одновременно выполняемых задач worker.
WORKER_CONCURRENCY=1
# Размер чанка потокового скачивания в байтах.
DOWNLOAD_CHUNK_SIZE=1048576
# Хост API-контейнера.
API_HOST=0.0.0.0
# Порт API-контейнера.
API_PORT=8000
# Часовой пояс сервиса.
APP_TIMEZONE=Europe/Moscow

