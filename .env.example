# Токен Telegram-бота. Получить у BotFather.
BOT_TOKEN=replace-me
# OAuth-токен Яндекс Диска для загрузки результата. Получить в кабинете Яндекс OAuth.
YANDEX_DISK_OAUTH_TOKEN=replace-me
# Базовый путь на Яндекс Диске, куда загружаются результаты.
YANDEX_DISK_BASE_PATH=/photo-processing/results
# Откуда брать входной архив: yandex или local.
ARCHIVE_SOURCE_MODE=yandex
# Куда складывать результат: yandex или local.
ARCHIVE_DESTINATION_MODE=yandex
# Путь к локальному входному ZIP-архиву внутри проекта. Используется, если ARCHIVE_SOURCE_MODE=local.
LOCAL_ARCHIVE_SOURCE_PATH=local-archives/input/archive.zip
# Папка внутри проекта, куда сохраняются готовые архивы. Используется, если ARCHIVE_DESTINATION_MODE=local.
LOCAL_ARCHIVE_RESULT_DIR=local-archives/output
# Режим запуска приложения: docker или local.
APP_RUNTIME_MODE=docker
# Docker-режим: PostgreSQL внутри docker compose.
DOCKER_DATABASE_URL=postgresql+asyncpg://photo_user:photo_password@postgres:5432/photo_processing
# Local-режим: PostgreSQL на локальной машине.
LOCAL_DATABASE_URL=postgresql+asyncpg://photo_user:photo_password@127.0.0.1:5432/photo_processing
# Docker-режим: Redis внутри docker compose.
DOCKER_REDIS_URL=redis://redis:6379/0
# Local-режим: Redis на локальной машине.
LOCAL_REDIS_URL=redis://127.0.0.1:6379/0
# Docker-режим: временное хранилище задач.
DOCKER_JOB_STORAGE_ROOT=/tmp/jobs
# Local-режим: временное хранилище задач.
LOCAL_JOB_STORAGE_ROOT=tmp/jobs-local
# Docker-режим: левый логотип внутри контейнера.
DOCKER_LEFT_LOGO_PATH=/app/assets/logo-left.png
# Local-режим: левый логотип в рабочей директории проекта.
LOCAL_LEFT_LOGO_PATH=app/assets/logo-left.png
# Docker-режим: правый логотип внутри контейнера.
DOCKER_RIGHT_LOGO_PATH=/app/assets/logo-right.png
# Local-режим: правый логотип в рабочей директории проекта.
LOCAL_RIGHT_LOGO_PATH=app/assets/logo-right.png
# Прозрачность логотипов на итоговом изображении: 1.0 — непрозрачные, 0.0 — полностью прозрачные.
LOGO_OPACITY=0.55
# Необязательные явные override-переменные. Если задать, они имеют приоритет над APP_RUNTIME_MODE.
# DATABASE_URL=
# REDIS_URL=
# JOB_STORAGE_ROOT=
# LEFT_LOGO_PATH=
# RIGHT_LOGO_PATH=
# Максимальный размер входного архива в байтах.
MAX_ARCHIVE_SIZE_BYTES=5368709120
# Максимальное количество файлов в архиве.
MAX_ARCHIVE_FILES=300
# Максимальное количество изображений в обработке.
MAX_IMAGE_FILES=200
# Число потоков обработки изображений внутри одной задачи.
IMAGE_PROCESSING_CONCURRENCY=2
# Число одновременно выполняемых задач worker.
WORKER_CONCURRENCY=1
# Размер чанка потокового скачивания в байтах.
DOWNLOAD_CHUNK_SIZE=1048576
# Размер чанка потоковой загрузки результата в Яндекс Диск в байтах.
YANDEX_UPLOAD_CHUNK_SIZE=8388608
# Таймаут одной попытки потоковой загрузки результата в Яндекс Диск, в секундах.
YANDEX_UPLOAD_TIMEOUT_SECONDS=3600
# Количество попыток загрузки готового архива в Яндекс Диск при сетевых сбоях.
YANDEX_UPLOAD_MAX_ATTEMPTS=3
# Пауза между повторными попытками загрузки в Яндекс Диск, в секундах.
YANDEX_UPLOAD_RETRY_DELAY_SECONDS=5
# Хост API-контейнера.
API_HOST=0.0.0.0
# Порт API-контейнера.
API_PORT=8000
# Часовой пояс сервиса.
APP_TIMEZONE=Europe/Moscow
# Тестовый режим: если true, рядом с основным результатом создаются два доп. архива RAW-декодирования для сравнения.
# Используйте только для диагностики качества декодирования, в обычной работе оставляйте false.
DECODE_DEBUG_EXPORTS_ENABLED=false
